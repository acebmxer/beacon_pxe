# ============================================================================
# Beacon configuration
# Copy to .env and edit, or run ./setup.sh which generates it for you.
# ============================================================================

# --- Project directory -------------------------------------------------------
# Absolute path to this directory on the HOST. Used by the self-update so that
# docker compose resolves relative volume paths (./data, etc.) correctly when
# it runs against the Docker daemon from inside the web container.
# setup.sh sets this automatically; manual installs must set it themselves.
PROJECT_DIR=

# --- Update channel ----------------------------------------------------------
# Which published image tag this deployment tracks. Controls both what
# `docker compose pull` installs and what the web UI's update check watches.
#
#   latest  Rolling main branch — updates on every commit merged to main.
#   stable  Tagged releases only. The update button lights up when a new
#           version is released, not when main changes.
#
# NOTE: :stable is published by the first release tagged after this feature
# landed. Until that release exists, only "latest" can be pulled — setting
# "stable" before then fails with "manifest unknown".
#
# Switching channels takes effect on the next update: the UI reports an update
# available, and applying it moves the stack onto the new channel. Switching
# latest -> stable installs an *older*, released build.
BEACON_TAG=latest

# --- Initial admin account ---------------------------------------------------
# Username for the default admin created on first start.
ADMIN_USER=admin
# Password for the default admin.
#   - Leave BLANK to have a strong password auto-generated and printed to the
#     container logs on first start (recommended).
#   - Or set your own value here.
ADMIN_PASSWORD=

# --- Image storage -----------------------------------------------------------
# Host path where uploaded OS ISO images are stored. This is mounted into the
# containers. It can be a local directory, or a path where you have mounted an
# NFS/SMB share (see README "Image storage on NFS/SMB").
IMAGE_PATH=./data/images

# --- Networking / boot -------------------------------------------------------
# The IP address of THIS server on the LAN that PXE clients will reach.
# Used in the iPXE menu and dnsmasq config. Auto-detected by setup.sh if blank.
SERVER_IP=

# Network interface dnsmasq listens on for DHCP/proxyDHCP (e.g. eth0, ens18).
BOOT_INTERFACE=eth0

# DHCP mode: "proxy" (recommended, runs beside your existing DHCP server) or
# "full" (this box hands out IP addresses too). Can be changed later in the UI.
DHCP_MODE=proxy

# Only used when DHCP_MODE=full. Leave blank for proxyDHCP; fill these in (here
# or in the setup wizard) only if this box hands out IP addresses itself.
# Examples: DHCP_RANGE_START=192.168.1.100, DHCP_SUBNET_MASK=255.255.255.0
DHCP_RANGE_START=
DHCP_RANGE_END=
DHCP_SUBNET_MASK=
DHCP_GATEWAY=
DHCP_DNS=

# --- Web UI ------------------------------------------------------------------
# Port the management web UI listens on.
WEB_PORT=8080
# Secret used to sign session cookies. Auto-generated by setup.sh if blank.
SECRET_KEY=
